{
    "buildCommand": "nuxt build",
    "outputDirectory": ".output/public",
    "framework": "nuxt",
    "functions": {
        "*.js": {
            "runtime": "nodejs18.x"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}